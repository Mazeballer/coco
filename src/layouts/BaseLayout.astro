---
/**
 * BaseLayout.astro
 * The single root layout for every page.
 * - Imports global.css (Tailwind v4 + tokens + fonts)
 * - NO CDN scripts — everything is bundled at build time
 * - Full SEO meta, OG, Twitter Card
 */

import "../styles/global.css";

interface Props {
  title?:       string;
  description?: string;
  ogImage?:     string;
}

const {
  title       = "Coco Cado — Snack Happy",
  description = "Bold flavour, crunchy fun, and feel-good snacking for every moment. Coco Cado is a modern Malaysian snack brand by Happy Alliance.",
  ogImage     = "/images/og-image.jpg",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://cococado.com");
---

<!doctype html>
<html lang="en">

  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffd700" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- SEO Best Practices -->
    <meta name="robots" content="index, follow" />
    
    <!-- Structured Data -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Coco Cado",
        "url": "https://cococado.com",
        "logo": "https://cococado.com/favicon.svg",
        "description": "Bold flavour, crunchy fun, and feel-good snacking for every moment.",
        "sameAs": [
          "https://facebook.com/cococado",
          "https://instagram.com/cococado",
          "https://tiktok.com/@cococado"
        ]
      }
    </script>

    <!-- DNS Prefetch for Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <title>{title}</title>
  </head>

  <body class="overflow-x-hidden w-full max-w-[100vw]">
    <!-- Skip to main content — screen reader / keyboard accessibility -->
    <a href="#main-content" class="skip-link sr-only focus:not-sr-only">Skip to main content</a>

    <slot />
  </body>
</html>