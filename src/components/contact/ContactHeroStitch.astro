---
/**
 * ContactHeroStitch.astro
 * Hero banner for the Contact Us page.
 */
---

<header class="relative pt-36 pb-24 px-6 overflow-hidden bg-[#200f01] text-center">

  <!-- Ambient blobs -->
  <div class="absolute inset-0 opacity-25 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="absolute top-0 left-1/4 w-[32rem] h-[32rem] bg-[#ffd700] rounded-full blur-[150px] animate-pulse"></div>
    <div class="absolute bottom-0 right-1/4 w-[28rem] h-[28rem] bg-[#ce0301] rounded-full blur-[150px] animate-pulse" style="animation-delay:-2s;"></div>
  </div>

  <!-- "Talk Soon!" badge -->
  <div
    class="absolute top-1/2 right-10 -translate-y-1/2 hidden lg:flex items-center justify-center w-28 h-28 bg-[#ce0301] rounded-full border-4 border-white/20 shadow-2xl rotate-12 hover:rotate-6 hover:scale-110 transition-all duration-300 cursor-default z-10"
    aria-hidden="true"
  >
    <span class="font-headline font-black text-white text-center text-sm uppercase leading-tight">Talk<br/>Soon!</span>
  </div>

  <div class="max-w-7xl mx-auto relative z-10 space-y-4">
    <h1 class="text-6xl md:text-8xl font-headline font-black text-[#ffd700] tracking-tighter uppercase leading-none drop-shadow-2xl">
      Contact Us
    </h1>
    <p class="inline-block font-headline font-black text-lg md:text-xl text-white uppercase tracking-widest bg-[#ce0301] px-6 py-2 rounded-full">
      We would love to hear from you.
    </p>
  </div>

  <!-- SVG wave into next section -->
  <div class="absolute -bottom-5 left-0 w-full overflow-hidden leading-none translate-y-1" aria-hidden="true">
    <svg viewBox="0 0 1200 80" preserveAspectRatio="none" class="block w-full h-16 md:h-20" style="fill:#2a1705;">
      <path d="M0,40 C200,80 400,0 600,40 C800,80 1000,0 1200,40 L1200,80 L0,80 Z"/>
    </svg>
  </div>
</header>
