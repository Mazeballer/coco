---
/**
 * ContactFormStitch.astro
 * Two-column layout: contact form (left) + details & socials (right).
 * Form submits via Netlify Forms — no backend needed.
 */
import Icon from "../ui/Icon.astro";

const details = [
  {
    icon: "apartment",
    iconBg: "bg-[#ffd700]",
    iconText: "text-[#221b00]",
    rotate: "rotate-12",
    title: "COCO CADO HQ",
    subtitle: "Happy Alliance (M) Sdn. Bhd.",
  },
  {
    icon: "location_on",
    iconBg: "bg-[#ce0301]",
    iconText: "text-white",
    rotate: "-rotate-6",
    title: "Address",
    subtitle: "Lot 2869, Kampung Tumbuk,<br/>42800 Tanjong Sepat,<br/>Selangor D.E., Malaysia.",
  },
  {
    icon: "mail",
    iconBg: "bg-[#f2cdff]",
    iconText: "text-[#4e0a6f]",
    rotate: "rotate-3",
    title: "Emails",
    subtitle: "sales@cococado.com.my",
  },
  {
    icon: "schedule",
    iconBg: "bg-[#999077]",
    iconText: "text-[#200f01]",
    rotate: "-rotate-12",
    title: "Hours",
    subtitle: "Mon – Fri: 8.30am – 5.30pm<br/>Sat: 8.30am – 12.00pm<br/>Sun & Public Holidays: Closed",
  },
];

const socials = [
  {
    label: "Instagram",
    handle: "@cococado",
    href: "https://www.instagram.com/cococado.my/",
    iconBg: "bg-gradient-to-br from-pink-500 to-yellow-500",
    isSvg: true,
    svgPath: "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
  },
  {
    label: "TikTok",
    handle: "@cococado.my",
    href: "https://www.tiktok.com/@cococadomy",
    iconBg: "bg-[#010101]",
    isSvg: true,
    svgPath: "M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.04-.1z"
  },
  {
    label: "Facebook",
    handle: "Coco Cado",
    href: "https://www.facebook.com/people/Coco-Cado/61585906421654",
    iconBg: "bg-[#1877F2]",
    isSvg: true,
    svgPath: "M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
  },
];

const mapsUrl = "https://maps.google.com/?q=Lot+2869+Kampung+Tumbuk+42800+Tanjong+Sepat+Selangor+Malaysia";
---

<section class="bg-[#2a1705] py-24 px-6">
  <div class="max-w-7xl mx-auto">

    <!-- Intro -->
    <p class="text-center text-xl md:text-2xl font-medium text-[#d0c6ab] max-w-3xl mx-auto mb-16 leading-snug">
      Got a craving? A question? Or just want to share the snack love? We're all ears (and taste buds). Reach out and let's get the flavour conversation started!
    </p>

    <div class="grid md:grid-cols-2 gap-12 items-start">

      <!-- LEFT: Contact Form -->
      <div class="relative group">
        <!-- Solid "Long" Background Layer - Extending significantly bottomwards as per reference -->
        <div 
          class="absolute top-10 left-10 -bottom-48 -right-10 bg-[#2d1e18] rounded-[4rem] -z-10 transition-transform duration-500 group-hover:translate-x-3 group-hover:translate-y-3 opacity-100 shadow-2xl" 
          aria-hidden="true"
        ></div>

        <div class="bg-[#3a2512] rounded-[3rem] p-10 md:p-12 border-4 border-[#999077]/40 shadow-2xl relative z-10 transition-all duration-300">
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="space-y-6"
          >
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden" aria-hidden="true">
              <label>Don't fill: <input name="bot-field" /></label>
            </p>

            <div class="space-y-2">
              <label for="full-name" class="block font-headline font-bold text-xs uppercase tracking-wider text-[#ffd700]">
                Full Name
              </label>
              <input
                id="full-name"
                name="full-name"
                type="text"
                required
                placeholder="Your name here..."
                class="w-full bg-[#200f01] text-white border-none rounded-xl px-4 py-3 text-base placeholder:text-[#999077] focus:ring-2 focus:ring-[#ffd700] focus:outline-none transition-all"
              />
            </div>

            <div class="grid sm:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label for="contact-email" class="block font-headline font-bold text-xs uppercase tracking-wider text-[#ffd700]">
                  Email
                </label>
                <input
                  id="contact-email"
                  name="email"
                  type="email"
                  required
                  placeholder="hello@you.com"
                  class="w-full bg-[#200f01] text-white border-none rounded-xl px-4 py-3 text-base placeholder:text-[#999077] focus:ring-2 focus:ring-[#ffd700] focus:outline-none transition-all"
                />
              </div>
              <div class="space-y-2">
                <label for="contact-phone" class="block font-headline font-bold text-xs uppercase tracking-wider text-[#ffd700]">
                  Phone
                </label>
                <input
                  id="contact-phone"
                  name="phone"
                  type="tel"
                  placeholder="+60 ..."
                  class="w-full bg-[#200f01] text-white border-none rounded-xl px-4 py-3 text-base placeholder:text-[#999077] focus:ring-2 focus:ring-[#ffd700] focus:outline-none transition-all"
                />
              </div>
            </div>

            <div class="space-y-2">
              <label for="subject" class="block font-headline font-bold text-xs uppercase tracking-wider text-[#ffd700]">
                Subject
              </label>
              <select
                id="subject"
                name="subject"
                class="w-full bg-[#200f01] text-white border-none rounded-xl px-4 py-3 text-base focus:ring-2 focus:ring-[#ffd700] focus:outline-none transition-all appearance-none cursor-pointer"
              >
                <option value="product-inquiry">Product Inquiry</option>
                <option value="feedback">Feedback</option>
                <option value="wholesale">Wholesale</option>
                <option value="media-press">Media / Press</option>
              </select>
            </div>

            <div class="space-y-2">
              <label for="contact-message" class="block font-headline font-bold text-xs uppercase tracking-wider text-[#ffd700]">
                Message
              </label>
              <textarea
                id="contact-message"
                name="message"
                rows="4"
                required
                placeholder="What's on your mind?"
                class="w-full bg-[#200f01] text-white border-none rounded-xl px-4 py-3 text-base placeholder:text-[#999077] focus:ring-2 focus:ring-[#ffd700] focus:outline-none transition-all resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-[#ce0301] text-white font-headline font-black text-xl py-5 rounded-full uppercase tracking-widest hover:rotate-1 hover:scale-[1.02] active:scale-95 transition-all shadow-[0_8px_0_#6a0000] border-2 border-[#6a0000]"
            >
              Send Message
            </button>
          </form>
        </div>
      </div>

      <!-- RIGHT: Details & Socials -->
      <div class="space-y-8">

        <!-- Details card -->
        <div class="bg-[#3a2512] rounded-[2rem] p-8 md:p-10 border-4 border-[#ffd700]/20 shadow-2xl rotate-1 space-y-8">

          {details.map((d) => (
            <div class="flex items-start gap-4">
              <div class={`${d.iconBg} ${d.iconText} p-3 rounded-xl ${d.rotate} shadow-md shrink-0`}>
                <Icon name={d.icon as any} class="w-6 h-6" />
              </div>
              <div>
                <p class="font-headline font-black text-base uppercase text-[#ffd700] mb-1">{d.title}</p>
                <p class="text-[#d0c6ab] text-sm font-medium leading-relaxed" set:html={d.subtitle}></p>
              </div>
            </div>
          ))}

          <!-- Map placeholder -->
          <div class="rounded-[1.5rem] overflow-hidden h-44 bg-[#200f01] relative border-2 border-[#999077]/20">
            <!-- Styled map bg -->
            <div class="w-full h-full" style="background: linear-gradient(135deg, #1a0a00 0%, #2f1b08 50%, #200f01 100%); position:relative;">
              <!-- Grid lines for map feel -->
              <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(#999077 1px, transparent 1px), linear-gradient(90deg, #999077 1px, transparent 1px); background-size: 30px 30px;" aria-hidden="true"></div>
              <!-- Location dot -->
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 flex flex-col items-center gap-2" aria-hidden="true">
                <div class="w-4 h-4 bg-[#ce0301] rounded-full shadow-[0_0_0_6px_rgba(206,3,1,0.3)]"></div>
              </div>
            </div>
            <!-- Open in Maps button -->
            <div class="absolute inset-0 flex items-center justify-center">
              <a
                href={mapsUrl}
                target="_blank"
                rel="noopener noreferrer"
                 class="bg-[#ffd700] text-[#221b00] px-5 py-2 rounded-full font-headline font-black text-sm uppercase flex items-center gap-2 shadow-xl hover:scale-105 transition-transform"
               >
                 <Icon name="explore" class="w-4 h-4" />
                 Open in Maps
               </a>
            </div>
          </div>
        </div>

        <!-- Socials -->
        <div class="space-y-5 px-2">
          <h3 class="font-headline font-black text-2xl uppercase italic text-[#f2cdff]">Connect With Us</h3>
          <div class="flex flex-wrap gap-4">
            {socials.map((s) => (
              <a
                href={s.href}
                aria-label={`Follow Coco Cado on ${s.label}`}
                class="group flex items-center gap-4 bg-[#3a2512] border-2 border-[#999077]/20 p-2 pr-6 rounded-xl hover:scale-105 hover:border-[#ffd700]/30 transition-all shadow-md"
              >
                <div class={`w-12 h-12 ${s.iconBg} rounded-xl flex items-center justify-center text-white shadow-md shrink-0`}>
                  {s.isSvg ? (
                    <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                      <path d={s.svgPath} />
                    </svg>
                  ) : (
                    <span class="material-symbols-outlined text-2xl" aria-hidden="true">{s.icon}</span>
                  )}
                </div>
                <div>
                  <p class="font-headline font-black text-base uppercase leading-none text-white">{s.label}</p>
                  <p class="text-[#999077] text-xs mt-0.5">{s.handle}</p>
                </div>
              </a>
            ))}
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
