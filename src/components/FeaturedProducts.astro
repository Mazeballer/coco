---
import ProductCard from './ProductCard.astro';
import potatoImg from '../assets/potatoSticksHome.svg';
import pearlImg from '../assets/poppingPearlsHome.svg';

const products = [
  {
    image: pearlImg,
    alt: 'Popping pearl',
    badge: 'BURSTING WITH FLAVOUR!',
    title: 'Popping pearl ',
    desc: 'Fun, flavourful snacks for all-day enjoyment.',
  },
  {
    image: potatoImg,
    alt: 'Potato Sticks',
    badge: 'CRUNCHY!',
    title: 'Potato Sticks',
    desc: "Light, crispy, and addictive with bold seasoning.",
  },
];
---

<section class="bg-[#ffd700] py-32" aria-labelledby="products-heading">
  <div class="container mx-auto px-6">
    <header class="text-center mb-20">
      <span class="inline-block bg-[#200f01] text-[#ffd700] px-6 py-2 rounded-full font-black text-sm tracking-widest uppercase mb-4">Snack Picks</span>
      <h2 id="products-heading" class="text-3xl md:text-5xl lg:text-6xl font-black font-headline text-[#200f01] leading-[1.1] max-w-4xl mx-auto text-balance">
        DISCOVER THE <span class="text-[#ce0301]">SNACKS</span> EVERYONE WILL<br class="hidden md:block" /> REACH FOR <span class="text-[#ce0301]">AGAIN AND AGAIN.</span>
      </h2>
    </header>

    <ul class="grid grid-cols-1 md:grid-cols-2 gap-y-16 gap-x-8 pt-16 md:pt-24 list-none m-0 p-0 max-w-4xl mx-auto" role="list" aria-label="Featured snack products">
      {products.map((p) => (
        <ProductCard image={p.image} alt={p.alt} badge={p.badge} title={p.title} desc={p.desc} />
      ))}
    </ul>
  </div>
</section>
