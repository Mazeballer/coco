---
import Icon from "./ui/Icon.astro";
const navLinks = [
  { label: "Products",     href: "/products"      },
  { label: "About",        href: "/about"         },
  { label: "Ambassadors",  href: "/ambassadors"   },
  { label: "News",         href: "/news"          },
  { label: "WHERE TO BUY", href: "/where-to-buy"  },
  { label: "Contact",      href: "/contact"       },
];

const currentPath = Astro.url.pathname;
---

<header class="group fixed top-0 w-full z-[100] bg-transparent backdrop-blur-none shadow-none will-change-transform transition-[background,box-shadow] duration-300 ease-out hover:bg-[#1a0a00]/95 hover:backdrop-blur-md hover:shadow-2xl hover:shadow-black/50">
  <nav
    class="flex justify-between items-center px-6 md:px-10 py-6 max-w-[1920px] mx-auto"
    aria-label="Main navigation"
  >

    <!-- Logo left -->
    <a
      href="/"
      class="inline-block hover:scale-105 transition-transform active:scale-95 shrink-0"
      aria-label="Coco Cado Home"
    >
      <span
        class="block bg-[#cc0000] px-5 py-2"
        style="
          border-radius: 9999px;
          border: 4px solid #1a0a00;
          box-shadow: inset 0 0 0 2px #ffffff;
        "
      >
        <span
          class="block text-white uppercase leading-none"
          style="font-family: 'Epilogue', sans-serif; font-weight: 900; font-size: 1.25rem; letter-spacing: 0.1em;"
        >
          COCO CADO
        </span>
      </span>
    </a>

    <!-- Desktop links right -->
    <ul class="hidden md:flex gap-8 items-center list-none m-0 p-0 font-headline tracking-tighter uppercase font-bold text-sm" role="list">
      {navLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class:list={[
              "transition-colors duration-300 ease-out hover:scale-105 inline-block",
              currentPath === href
                ? "text-[#ce0301] border-b-2 border-[#ce0301] pb-1"
                : "text-[#200f01] group-hover:text-white group-focus-within:text-white hover:text-white focus:text-white",
            ]}
            aria-current={currentPath === href ? "page" : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-[#ffe792] p-2 rounded-lg hover:bg-white/5 transition-colors"
      aria-label="Open mobile menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      type="button"
    >
      <Icon name="menu" class="w-8 h-8" />
    </button>

  </nav>

  <!-- Mobile dropdown -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-[#1a0a00] border-t border-white/10 px-6 py-6"
    role="dialog"
    aria-label="Mobile navigation"
  >
    <ul class="flex flex-col gap-2 list-none m-0 p-0" role="list">
          {navLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class:list={[
              "block font-headline font-bold uppercase text-sm tracking-wider py-3 px-4 rounded-lg transition-colors",
              currentPath === href
                ? "text-[#ffd700] bg-white/10"
                : "text-white hover:text-[#ffd700] hover:bg-white/5",
            ]}
            aria-current={currentPath === href ? "page" : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>

</header>

  <script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const headerEl = document.querySelector('header');
  const hero = document.getElementById('hero-scroll');

  if (btn && menu) {
    btn.addEventListener("click", () => {
      const isOpen = !menu.classList.contains("hidden");
      menu.classList.toggle("hidden", isOpen);
      btn.setAttribute("aria-expanded", String(!isOpen));
      btn.setAttribute("aria-label", isOpen ? "Open mobile menu" : "Close mobile menu");

      // when mobile menu opens, keep header visible
      if (!isOpen) {
        headerEl && headerEl.classList.remove('-translate-y-full');
      }
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
      });
    });
  }

  // Show brown background as soon as the user scrolls, keep it from then on.
  if (headerEl) {
    let ticking = false;

    const enableHeaderBg = () => {
      headerEl.classList.add('scrolled');
    };

    const disableHeaderBg = () => {
      headerEl.classList.remove('scrolled');
    };

    const handle = () => {
      const currentY = window.scrollY || 0;

      // Turn on the dark background as soon as the user scrolls down a bit
      // to prevent the transparent navbar from clashing with scrolling text
      const offset = 50;

      if (currentY >= offset) {
        enableHeaderBg();
      } else {
        disableHeaderBg();
      }

      ticking = false;
    };

    // Run once on load in case page restores scroll position
    handle();

    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(handle);
        ticking = true;
      }
    }, { passive: true });
  }
</script>

<style>
  /* Scrolled state — brown background locks in */
  header.scrolled {
    background-color: rgba(26, 10, 0, 0.95);
    backdrop-filter: blur(12px);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }

  /* Make all non-active links white when scrolled for readability */
  header.scrolled nav a:not([aria-current="page"]) {
    color: #ffffff !important;
  }
  header.scrolled #mobile-menu a:not([aria-current="page"]) {
    color: #ffffff !important;
  }
</style>