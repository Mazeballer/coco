---
/**
 * ExportOpportunitiesStitch.astro
 * Section highlighting global export markets.
 */

const countries = [
  { name: "ASIA",   color: "bg-[#ce0301]" },
  { name: "Middle East",  color: "bg-[#0b1c48]" },
  { name: "Europe", color: "bg-[#286310]" },
  { name: "OCEANIA",  color: "bg-[#4f1063]" },
  { name: "North America",  color: "bg-[#105f63]" },
  { name: "South America",  color: "bg-[#626310]" },
  { name: "AFRICA",  color: "bg-[#fad502]" },
];

import { Image } from "astro:assets";
import mapImage from "../../assets/map.png";
---

<section class="py-24 px-6 bg-[#200f01] relative overflow-hidden">
  <!-- Ambient glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[40rem] h-[40rem] bg-[#ce0301] opacity-[0.04] blur-[120px] pointer-events-none" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-20 items-center">

    <!-- Text -->
    <div class="export-reveal order-2 lg:order-1 space-y-8">
      <div class="space-y-4">
        <h2 class="text-4xl md:text-6xl font-headline font-black text-[#ce0301] uppercase tracking-tighter leading-none">
          Export Opportunities
        </h2>
        <p class="text-lg md:text-xl text-[#d0c6ab] leading-snug font-medium italic opacity-90 max-w-lg">
          Backed by Happy Alliance's manufacturing experience and global business ambition, Coco Cado is positioned for broader regional and export growth. We welcome inquiries from importers, distributors, and market partners.
        </p>
      </div>

      <div class="flex flex-wrap gap-4">
        {countries.map((c) => (
          <div class="px-6 py-3 bg-[#2f1b08] rounded-full border-2 border-[#999077]/30 flex items-center gap-3 hover:border-[#ffd700] hover:scale-105 transition-all cursor-default group shadow-md">
            <span class={`w-7 h-4 ${c.color} rounded-sm shadow-sm group-hover:scale-110 transition-transform`} aria-hidden="true"></span>
            <span class="font-headline font-black text-sm tracking-widest text-[#ffdcc0]">{c.name}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Map image -->
    <div class="export-reveal order-1 lg:order-2">
      <div class="relative bg-[#2f1b08] rounded-[2.5rem] p-4 shadow-2xl border-2 border-[#999077]/20 group">
        <div class="rounded-[2rem] overflow-hidden aspect-[4/3] bg-[#1a0a00] relative">
          <Image
            src={mapImage}
            alt="Map of Southeast Asia showing Coco Cado export markets"
            width={1200}
            quality="max"
            loading="lazy"
            class="w-full h-full object-cover opacity-80 group-hover:scale-105 group-hover:opacity-100 transition-all duration-700"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#200f01] via-transparent to-transparent opacity-60" aria-hidden="true"></div>

          <div class="absolute inset-x-0 bottom-8 flex items-center justify-center">
            <span class="bg-[#ffd700] text-[#200f01] px-8 py-2 rounded-full font-headline font-black text-xs tracking-[0.2em] uppercase shadow-xl">
              Global Export Markets
            </span>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .export-reveal {
    opacity: 0;
    transform: translateY(40px);
  }
</style>
