---

<section class="py-32 bg-surface-container-lowest overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <h3 class="font-headline font-black text-4xl md:text-5xl uppercase tracking-tighter mb-20 text-white">
      Campaign Moments
    </h3>
    
    <div class="flex flex-wrap gap-8 justify-center">
      {moments.map((moment) => (
        <div class="relative group gsap-reveal-moment w-full md:w-[calc(33.333%-2rem)] max-w-sm">
          <div class={`overflow-hidden border-4 border-stone-800 ${moment.blobClass} group-hover:scale-102 transition-transform duration-500 bg-stone-800`}>
            <img 
              src={moment.image} 
              alt={moment.imageAlt}
              class="w-full h-full object-cover aspect-square"
            />
          </div>
          <div class={`absolute bottom-4 right-4 ${moment.badgeColor} font-headline font-bold px-3 py-1 rounded-sm shadow-xl ${moment.rotate} group-hover:scale-110 transition-all duration-300 text-[10px] uppercase tracking-tighter z-10`}>
            {moment.caption}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
