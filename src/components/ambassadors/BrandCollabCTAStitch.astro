---
/**
 * BrandCollabCTAStitch.astro
 * High-contrast call to action for brand collaborations.
 */

interface Props {
  titleLine1: string;
  titleLine2: string;
  description: string;
  buttonText: string;
  buttonHref: string;
}

const { titleLine1, titleLine2, description, buttonText, buttonHref } = Astro.props;
---

<section class="py-32 px-6">
  <div class="max-w-6xl mx-auto bg-[#ce0301] rounded-[2.5rem] p-12 md:p-24 text-center relative overflow-hidden group shadow-2xl">
    <!-- Animated atmospheric blobs -->
    <div class="absolute -top-20 -left-20 w-64 h-64 bg-black opacity-10 rounded-full blur-3xl group-hover:scale-125 transition-transform duration-1000"></div>
    <div class="absolute -bottom-20 -right-20 w-80 h-80 bg-white opacity-10 rounded-full blur-3xl group-hover:scale-125 transition-transform duration-1000"></div>
    
    <div class="relative z-10 space-y-10">
      <h2 class="font-headline font-black text-6xl md:text-[6.5rem] text-white uppercase tracking-tighter leading-[0.8] mb-4">
        {titleLine1} <br/> 
        {titleLine2}
      </h2>
      <p class="text-white text-lg md:text-xl font-medium max-w-xl mx-auto opacity-90">
        {description}
      </p>
      <a
href={buttonHref}
  class="inline-block bg-[#ffd700] text-black px-10 py-4 rounded-full font-headline font-black text-xl uppercase tracking-tighter shadow-[0_8px_0_#b29600] border-2 border-[#b29600]/20 hover:scale-105 active:scale-95 transition-all"
>
  {buttonText}
</a>
    </div>
  </div>
</section>
