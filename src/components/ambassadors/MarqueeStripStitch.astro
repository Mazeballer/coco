---
/**
 * MarqueeStripStitch.astro
 * Infinite scrolling text strip using GSAP for smoothness.
 */

interface Props {
  text1: string;
  text2: string;
  text3: string;
  text4: string;
}

const { text1, text2, text3, text4 } = Astro.props;
---

<section class="py-12 bg-[#ffd700] overflow-hidden border-y-4 border-black/10">
  <div class="marquee-container flex items-center gap-12 whitespace-nowrap">
    <!-- Duplicate content for seamless loop -->
    <div class="marquee-content flex items-center gap-12">
      <span class="font-headline font-black text-4xl md:text-5xl text-black uppercase tracking-tighter italic">{text1}</span>
      <span class="material-symbols-outlined text-4xl text-secondary-container">favorite</span>
      <span class="font-headline font-black text-4xl md:text-5xl text-black uppercase tracking-tighter italic">{text2}</span>
      <span class="material-symbols-outlined text-4xl text-black/40">bolt</span>
      <span class="font-headline font-black text-4xl md:text-5xl text-black uppercase tracking-tighter italic">{text3}</span>
      <span class="material-symbols-outlined text-4xl text-[#ce0301]">star</span>
      <span class="font-headline font-black text-4xl md:text-5xl text-black uppercase tracking-tighter italic">{text4}</span>
      <span class="material-symbols-outlined text-4xl text-black/20">rocket_launch</span>
    </div>
    <div class="marquee-content flex items-center gap-12" aria-hidden="true">
      <span class="font-headline font-black text-4xl md:text-5xl text-black uppercase tracking-tighter italic">{text1}</span>
      <span class="material-symbols-outlined text-4xl text-secondary-container">favorite</span>
      <span class="font-headline font-black text-4xl md:text-5xl text-black uppercase tracking-tighter italic">{text2}</span>
      <span class="material-symbols-outlined text-4xl text-black/40">bolt</span>
      <span class="font-headline font-black text-4xl md:text-5xl text-black uppercase tracking-tighter italic">{text3}</span>
      <span class="material-symbols-outlined text-4xl text-[#ce0301]">star</span>
      <span class="font-headline font-black text-4xl md:text-5xl text-black uppercase tracking-tighter italic">{text4}</span>
      <span class="material-symbols-outlined text-4xl text-black/20">rocket_launch</span>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  function initMarquee() {
    const container = document.querySelector('.marquee-container');
    const content = document.querySelector('.marquee-content');
    
    if (!container || !content) return;

    // Get the width of one set of content
    const width = (content as HTMLElement).offsetWidth;

    // Animate the container to shift exactly one content-width to the left
    gsap.to('.marquee-container', {
      x: -width - 48, // width + gap
      duration: 30,
      ease: "none",
      repeat: -1
    });
  }

  // Initialize on load and when content might change
  window.addEventListener('load', initMarquee);
  document.addEventListener('astro:page-load', initMarquee);
</script>
