---
/**
 * AmbassadorIntroStitch.astro
 * High-scale statement section with wavy underline and colored highlights.
 */

interface Props {
  text: string; // The text content with parts to highlight handled via slots or regex if needed.
}

// For simplicity in this conversion, we'll use a slot for the rich text
---

<section class="py-32 px-6 md:px-12 max-w-6xl mx-auto text-center" id="ambassador-intro-section">
  <div class="gsap-reveal-intro">
    <h2 class="font-headline font-black text-4xl md:text-6xl leading-[1.3] text-on-surface tracking-tighter uppercase mb-0">
      <slot />
    </h2>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initTextReveal = () => {
    const heading = document.querySelector("#ambassador-intro-section .gsap-reveal-intro h2");
    if (!heading) return;

    // Recursive function to wrap every word in a span for individual animation
    const splitWords = (element: HTMLElement | ChildNode) => {
      const nodes = Array.from(element.childNodes);
      
      // Clear content to rebuild with spans
      if (element instanceof HTMLElement) element.innerHTML = '';
      
      nodes.forEach(node => {
        if (node.nodeType === Node.TEXT_NODE) {
          const text = node.textContent || "";
          const words = text.split(/(\s+)/);
          
          words.forEach(word => {
            if (word.trim().length > 0) {
              const span = document.createElement('span');
              span.className = 'reveal-word opacity-20 transition-opacity duration-300 inline';
              span.textContent = word;
              element.appendChild(span);
            } else {
              element.appendChild(document.createTextNode(word));
            }
          });
        } else if (node.nodeType === Node.ELEMENT_NODE) {
          const el = node as HTMLElement;
          const clonedNode = el.cloneNode(true) as HTMLElement;
          // Recursively split words inside highlight spans
          splitWords(clonedNode);
          element.appendChild(clonedNode);
        }
      });
    };

    splitWords(heading);

    // GSAP ScrollTrigger
    const words = heading.querySelectorAll('.reveal-word');
    
    gsap.to(words, {
      opacity: 1,
      duration: 0.1,
      stagger: 0.1,
      scrollTrigger: {
        trigger: "#ambassador-intro-section",
        start: "top 75%",
        end: "bottom 60%", // End before the section leaves the viewport
        scrub: true,
      }
    });
  };

  // Run on load
  window.addEventListener('load', initTextReveal);
  if (document.readyState === 'complete') initTextReveal();
</script>

<style is:global>
  .underline-wavy {
    text-decoration: underline;
    text-decoration-style: wavy;
    text-decoration-color: var(--color-secondary-container);
    text-underline-offset: 12px;
  }

  .reveal-word {
    display: inline;
    will-change: opacity;
  }
</style>
