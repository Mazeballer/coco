---
/**
 * AmbassadorHeroStitch.astro
 * High-impact hero section for the Ambassadors page.
 */

interface Props {
  titleLine1: string;
  titleLine2: string;
  titleLine3: string;
  subtitle: string;
  tag: string;
  badge: string;
  image: string;
  imageAlt: string;
}

const { 
  titleLine1, 
  titleLine2, 
  titleLine3, 
  subtitle, 
  tag, 
} = Astro.props;
---

<header class="relative pt-48 pb-40 px-6 md:px-12 bg-[#ffd700] overflow-hidden">
  <!-- Dynamic Background Element (Sticker style) -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[60rem] h-[60rem] bg-[#f9a825]/20 rounded-full blur-[100px] pointer-events-none" aria-hidden="true"></div>

  <div class="max-w-4xl mx-auto text-center relative z-10 space-y-10">
    
    <div class="space-y-6">
      <div class="hero-animate-reveal inline-block bg-[#ce0301] text-white px-6 py-2 rounded-full font-headline font-black uppercase tracking-[0.2em] text-xs -rotate-2 shadow-lg">
        {tag}
      </div>
      
      <h1 class="hero-animate-reveal font-headline font-black text-6xl md:text-[7rem] text-[#200f01] leading-[0.85] tracking-tighter uppercase">
        {titleLine1} <br/> 
        {titleLine2} <br/> 
        <span class="text-[#ce0301] block mt-2">{titleLine3}</span>
      </h1>

      <div class="hero-animate-reveal flex justify-center gap-4 py-2" aria-hidden="true">
        <div class="h-1.5 w-24 bg-[#ce0301] rounded-full"></div>
        <div class="h-1.5 w-12 bg-[#200f01] rounded-full"></div>
      </div>

      <p class="hero-animate-reveal text-[#200f01] text-xl md:text-3xl font-medium max-w-2xl mx-auto leading-tight italic opacity-90">
        {subtitle}
      </p>
    </div>

  </div>

  <!-- Gentle Rolling Wavy Divider Transition to next section -->
  <div class="absolute -bottom-[1px] left-0 w-full overflow-hidden leading-none z-10" aria-hidden="true">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="block w-full h-20 md:h-28 fill-[#200f01]">
      <path d="M0,40 C180,80 360,0 540,40 C720,80 900,0 1080,40 C1260,80 1440,0 1440,40 L1440,80 L0,80 Z"></path>
    </svg>
  </div>
</header>
