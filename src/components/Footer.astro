---
/**
 * Footer.astro
 * Site-wide footer with brand info, nav, resources, and newsletter form.
 * Newsletter form submits to Web3Forms — no backend needed.
 */

import { Image } from "astro:assets";
import logoImg from "../assets/logo.png";
import Icon from "./ui/Icon.astro";

const navLinks = [
  { label: "Home",        href: "/"             },
  { label: "Products",    href: "/products"     },
  { label: "About",       href: "/about"        },
  { label: "Campaigns",   href: "/campaigns"    },
  { label: "News",        href: "/news"         },
  { label: "Where to Buy", href: "/where-to-buy" },
  { label: "Contact",     href: "/contact"      },
];

const resourceLinks = [
  { label: "Privacy Policy", href: "/privacy"       },
];

const socialLinks = [
  { 
    label: "Instagram", 
    href: "https://www.instagram.com/cococado.my/", 
    isSvg: true,
    svgPath: "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
  },
  { 
    label: "TikTok", 
    href: "https://www.tiktok.com/@cococadomy",
    isSvg: true,
    svgPath: "M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.04-.1z"
  },
  { 
    label: "Facebook", 
    href: "https://www.facebook.com/people/Coco-Cado/61585906421654",
    isSvg: true,
    svgPath: "M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
  },
];

const year = new Date().getFullYear();
---

<footer class="w-full bg-[#1a0a00] pt-24 pb-12">
  <div class="container mx-auto px-6">

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">

      <!-- Brand info -->
      <div class="space-y-6">
        <a
          href="/"
          class="inline-block -ml-1 hover:scale-105 transition-transform active:scale-95"
          aria-label="Coco Cado Home"
        >
          <Image 
            src={logoImg} 
            alt="Coco Cado Logo" 
            width={240}
            densities={[1.5, 2, 3]}
            quality={100}
            class="h-auto w-37 md:w-45"
          />
        </a>
        <address class="text-[#999077] text-sm leading-relaxed font-medium not-italic">
          Happy Alliance (M) Sdn. Bhd.<br />
          Lot 2869, Kampung Tumbuk,<br />
          42800 Tanjong Sepat,<br />
          Selangor D.E., Malaysia.
        </address>
        <ul class="flex gap-4 list-none m-0 p-0" role="list" aria-label="Social media links">
          {socialLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                aria-label={`Follow Coco Cado on ${label}`}
                class="w-10 h-10 bg-[#2f1b08] rounded-full flex items-center justify-center hover:bg-[#ce0301] transition-colors group"
              >
                {/* @ts-ignore */}
                {socialLinks.find(s => s.label === label)?.isSvg ? (
                  <svg class="w-5 h-5 fill-[#ffd700] group-hover:fill-white transition-colors" viewBox="0 0 24 24" aria-hidden="true">
                    {/* @ts-ignore */}
                    <path d={socialLinks.find(s => s.label === label)?.svgPath} />
                  </svg>
                ) : (
                  <Icon 
                    name="share" 
                    class="w-5 h-5 text-[#ffd700] group-hover:text-white transition-colors" 
                  />
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Navigation -->
      <nav aria-label="Footer navigation">
        <h2 class="text-white font-black uppercase tracking-widest text-sm mb-8">Navigation</h2>
        <ul class="space-y-4 text-sm font-bold list-none m-0 p-0" role="list">
          {navLinks.map(({ label, href }) => (
            <li>
              <a href={href} class="text-[#999077] hover:text-[#ffd700] transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

  <!-- Reach Us -->
<nav aria-label="Footer reach us">
  <h2 class="text-white font-black uppercase tracking-widest text-sm mb-8">Reach Us</h2>

  <div class="text-[#999077] text-sm font-medium space-y-6">

    <!-- Hotline -->
    <div>
          <p class="text-[#ffd700] font-bold uppercase text-xs">Hotline</p>
      <a
        href="tel:+60331972857"
        class="block hover:text-[#ffd700] transition-colors"
      >
        TEL: +603 3197 2857
      </a>
      <a
        href="tel:+60331973857"
        class="block hover:text-[#ffd700] transition-colors"
      >
        FAX: +603 3197 3857
      </a>
    </div>

    <!-- General Enquiry -->
    <div>
      <p class="text-[#ffd700] font-bold uppercase text-xs mb-2">General Enquiry</p>
      <a
        href="mailto:cococado@gmail.com"
        class="hover:text-[#ffd700] transition-colors break-all"
      >
        cococado@gmail.com
      </a>
    </div>

    <!-- Sales & Export -->
    <div>
      <p class="text-[#ffd700] font-bold uppercase text-xs mb-2">Sales & Export Enquiry</p>
      <a
        href="mailto:sales@captaindolphin.com.my"
        class="hover:text-[#ffd700] transition-colors break-all"
      >
        sales@cococado.com.my
      </a>
    </div>

  </div>
</nav>

   <!-- Operation Hours -->
<div>
  <h2 class="text-white font-black uppercase tracking-widest text-sm mb-4">Operation Hours</h2>
  <ul class="text-[#999077] text-sm font-medium space-y-3">
    <li>Mon – Fri (8.30am – 5.30pm)</li>
    <li>Sat – (8.30am – 12.00pm)</li>
    <li>Sun & Public Holiday – Off</li>
  </ul>
</div>

    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-[#999077]/20 flex flex-col items-center text-center gap-2">
      <p class="text-[#ffd700] text-xs opacity-75">
        &copy; {year}Happy Alliance (M) Sdn. Bhd. All Rights Reserved.
      </p>
    </div>

  </div>
</footer>
