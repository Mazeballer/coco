---
---

<div class="bg-primary-container py-12 overflow-hidden relative">
  <!-- Subtle dots pattern -->
  <div class="absolute inset-0 kinetic-bg-dots opacity-20 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-12">
      
      <div class="flex items-center gap-4 group">
        <div class="w-14 h-14 bg-[#200f01] text-white rounded-full flex items-center justify-center group-hover:scale-110 transition-all duration-500 shadow-lg border-2 border-white/20 group-hover:border-white">
          <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'wght' 700;">verified</span>
        </div>
        <span class="font-black text-on-primary-fixed uppercase leading-none tracking-tighter text-lg">
          Halal<br/><span class="text-[#ce0301]">Certified</span>
        </span>
      </div>

      <div class="flex items-center gap-4 group">
        <div class="w-14 h-14 bg-[#ce0301] text-white rounded-full flex items-center justify-center group-hover:scale-110 transition-all duration-500 shadow-lg border-2 border-white/20 group-hover:border-white">
          <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'wght' 700;">workspace_premium</span>
        </div>
        <span class="font-black text-on-primary-fixed uppercase leading-none tracking-tighter text-lg">
          Quality<br/><span class="text-[#ce0301]">Assured</span>
        </span>
      </div>

      <div class="flex items-center gap-4 group">
        <div class="w-14 h-14 bg-[#8243a2] text-white rounded-full flex items-center justify-center group-hover:scale-110 transition-all duration-500 shadow-lg border-2 border-white/20 group-hover:border-white">
          <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'wght' 700;">location_on</span>
        </div>
        <span class="font-black text-on-primary-fixed uppercase leading-none tracking-tighter text-lg">
          Made in<br/><span class="text-[#ce0301]">Malaysia</span>
        </span>
      </div>

      <div class="flex items-center gap-4 group">
        <div class="w-14 h-14 bg-[#ffd700] text-[#200f01] rounded-full flex items-center justify-center group-hover:scale-110 transition-all duration-500 shadow-lg border-2 border-[#200f01]/20 group-hover:border-[#200f01]">
          <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'wght' 700;">groups</span>
        </div>
        <span class="font-black text-on-primary-fixed uppercase leading-none tracking-tighter text-lg">
          Great for<br/><span class="text-[#ce0301]">Sharing</span>
        </span>
      </div>

    </div>
  </div>
</div>
