---
import { getImage } from "astro:assets";

interface Props {
  title:      string;
  subtitle:   string;
  image:      any; // Changed to accept imported image object
  imageAlt:   string;
  eager?:     boolean;
}

const { title, subtitle, image, imageAlt, eager = true } = Astro.props;

// Process the image at high resolution and max quality
const optimizedImage = typeof image !== 'string' 
  ? await getImage({ src: image, width: 1600, quality: 'max' })
  : { src: image };
---

<header class="pt-32 pb-20 px-8 relative overflow-hidden" style="background-color: #200f01;">

  <!-- Wavy line pattern overlay -->
  <div
    class="absolute inset-0 pointer-events-none opacity-50"
    style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;100&quot; height=&quot;20&quot; viewBox=&quot;0 0 100 20&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 10 Q 25 20 50 10 T 100 10&quot; fill=&quot;none&quot; stroke=&quot;rgba(153,144,119,0.1)&quot; stroke-width=&quot;1&quot;/%3E%3C/svg%3E'); background-size: 200px 40px;"
    aria-hidden="true"
  ></div>

  <!-- Animated blob top-left -->
  <div
    class="absolute pointer-events-none"
    style="top: -10%; left: -10%; width: 40%; height: 40%; background: radial-gradient(circle, rgba(255,215,0,0.08) 0%, transparent 70%); border-radius: 43% 57% 70% 30% / 30% 45% 55% 70%; animation: drift 20s infinite alternate linear; z-index: 0;"
    aria-hidden="true"
  ></div>

  <!-- Animated blob bottom-right -->
  <div
    class="absolute pointer-events-none"
    style="bottom: -10%; right: -5%; width: 50%; height: 50%; background: radial-gradient(circle, rgba(206,3,1,0.05) 0%, transparent 70%); border-radius: 50% 50% 30% 70% / 50% 30% 70% 50%; animation: drift 25s infinite alternate-reverse linear; z-index: 0;"
    aria-hidden="true"
  ></div>

  <!-- Content -->
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-12 relative z-10">

    <div class="flex-1 text-left z-10 space-y-6">
      <h1 class="hero-animate-reveal text-6xl md:text-7xl font-headline font-extrabold text-[#ffd700] leading-none tracking-tighter">
        {title}
      </h1>
      <p class="hero-animate-reveal text-xl md:text-2xl font-medium text-[#ffdcc0] max-w-lg opacity-90">
        {subtitle}
      </p>
      <div class="hero-animate-reveal flex gap-4" aria-hidden="true">
        <div class="h-2 w-24 bg-[#ce0301] rounded-full"></div>
        <div class="h-2 w-12 bg-[#f2cdff] rounded-full"></div>
      </div>
      <!-- Slot for extra content like CTA buttons or nav links -->
      <slot />
    </div>

    <div class="flex-1 md:flex-[1.2] relative">
      <div
        class="absolute -top-12 -right-12 w-64 h-64 bg-[#f2cdff]/20 rounded-full blur-3xl pointer-events-none"
        aria-hidden="true"
      ></div>
      <img
        src={optimizedImage.src}
        alt={imageAlt}
        width="1600"
        height="1200"
        loading={eager ? "eager" : "lazy"}
        fetchpriority={eager ? "high" : "auto"}
        decoding="async"
        class="hero-animate-image w-full h-auto drop-shadow-[0_20px_40px_rgba(26,10,0,0.6)] rotate-3 hover:rotate-0 transition-transform duration-500 md:scale-125 origin-center"
      />
    </div>

  </div>
</header>

<style>
  @keyframes drift {
    from { transform: rotate(0deg) scale(1); }
    to   { transform: rotate(360deg) scale(1.2); }
  }
</style>