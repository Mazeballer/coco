---
/**
 * NewsPaginationStitch.astro
 * Circular pagination controls.
 */

interface Props {
  totalPages: number;
  currentPage: number;
}

const { totalPages, currentPage } = Astro.props;

if (totalPages <= 1) return null;
---

<nav class="max-w-7xl mx-auto py-20 flex justify-center items-center gap-4">
  <!-- Prev Arrow -->
  {currentPage > 1 ? (
    <a 
      href={currentPage === 2 ? "/news" : `/news?page=${currentPage - 1}`}
      class="w-10 h-10 flex items-center justify-center text-[#200f01] border-2 border-[#200f01] rounded-full hover:bg-[#200f01] hover:text-white transition-all group scale-100 active:scale-95"
    >
      <span class="material-symbols-outlined text-2xl group-hover:-translate-x-1 transition-transform font-bold">chevron_left</span>
    </a>
  ) : (
    <div class="w-10 h-10 flex items-center justify-center text-stone-300 border-2 border-stone-200 rounded-full cursor-not-allowed">
      <span class="material-symbols-outlined text-2xl font-bold">chevron_left</span>
    </div>
  )}
  
  <!-- Page Numbers -->
  <div class="flex gap-4 items-center">
    {Array.from({ length: totalPages }).map((_, i) => {
      const pageNum = i + 1;
      const isActive = pageNum === currentPage;
      
      return (
        <a
          href={pageNum === 1 ? "/news" : `/news?page=${pageNum}`}
          class:list={[
            "w-10 h-10 flex items-center justify-center rounded-full font-headline font-black text-lg transition-all",
            isActive 
              ? "bg-[#ce0301] text-white shadow-sm" 
              : "text-[#200f01] border-2 border-transparent hover:border-[#200f01]"
          ]}
        >
          {pageNum}
        </a>
      );
    })}
  </div>
  
  <!-- Next Arrow -->
  {currentPage < totalPages ? (
    <a 
      href={`/news?page=${currentPage + 1}`}
      class="w-10 h-10 flex items-center justify-center text-[#200f01] border-2 border-[#200f01] rounded-full hover:bg-[#200f01] hover:text-white transition-all group scale-100 active:scale-95"
    >
      <span class="material-symbols-outlined text-2xl group-hover:translate-x-1 transition-transform font-bold">chevron_right</span>
    </a>
  ) : (
    <div class="w-10 h-10 flex items-center justify-center text-stone-300 border-2 border-stone-200 rounded-full cursor-not-allowed">
      <span class="material-symbols-outlined text-2xl font-bold">chevron_right</span>
    </div>
  )}
</nav>
