---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar     from "../components/Navbar.astro";
import Footer     from "../components/Footer.astro";
import { Image }  from "astro:assets";
import redBeanSpoonImg from "../assets/redBeanSpoon.png";
import building from "../assets/HappyAllianceNewBuilding.jpg"
import barleyBowlImg from "../assets/barleyBowl.png"
import redBeanPearl from "../assets/redBean.png"
import barleyPearl from "../assets/barley.png"
import waterChesnutPearl from "../assets/waterChesnut.png"

import halalLogo from "../assets/certificateLogos/Halal.png";
import haccpLogo from "../assets/certificateLogos/HACCP.png";
import isoLogo   from "../assets/certificateLogos/ISO22000.png";
import fdaLogo   from "../assets/certificateLogos/FDA.png";
import mestiLogo from "../assets/certificateLogos/MeSTI.png";
import gmpLogo   from "../assets/certificateLogos/GMP.png";

const certifications = [
  { img: halalLogo, label: "Halal Certificate", rotate: "rotate-2" },
  { img: haccpLogo, label: "HACCP Certificate", rotate: "-rotate-3" },
  { img: isoLogo,   label: "ISO 22000 Certificate", rotate: "rotate-1" },
  { img: fdaLogo,   label: "FDA Certificate", rotate: "-rotate-1" },
  { img: mestiLogo, label: "MeSTI Certificate", rotate: "rotate-3" },
  { img: gmpLogo,   label: "GMP Certificate", rotate: "-rotate-2" },
];

const milestones = [
  { year: "1996",  title: "The Start",      body: "Happy Alliance established its manufacturing roots in Tanjong Sepat, Selangor.",  bg: "bg-[#ce0301]", text: "text-white",      rotate: "-rotate-2" },
  { year: "2010",  title: "Global Reach",   body: "Expansion into international distribution networks and export markets.",           bg: "bg-[#f2cdff]", text: "text-[#4e0a6f]", rotate: "rotate-1",  offset: "md:mt-12" },
  { year: "2023",  title: "Coco Cado Born", body: "A fresh new brand identity built for the next generation of snack lovers.",        bg: "bg-[#ffd700]", text: "text-[#221b00]", rotate: "-rotate-1" },
  { year: "NOW", title: "Beyond",         body: "Innovation in flavours, retail expansion, and growing regional presence.",          bg: "bg-[#ce0301]", text: "text-white",      rotate: "rotate-2",  offset: "md:mt-12" },
];

const concepts = [
  { num: "01", title: "EXPRESSIVE", body: "Every bite is a conversation. Our flavours are bold, vibrant, and made to be shared." },
  { num: "02", title: "ACCESSIBLE", body: "Premium quality for everyone, everywhere. Great snacking should be universal." },
  { num: "03", title: "SOCIAL",     body: "Designed to be modern, shareable, and full of personality for today's snack culture." },
];

const alliancePoints = [
  { icon: "verified_user", color: "text-[#f2cdff]", title: "Legacy & Trust",   body: "Founded in 1996, Happy Alliance has decades of experience producing quality food products.",          rotate: "" },
  { icon: "factory",       color: "text-[#ffd700]", title: "State-of-the-Art", body: "Modern production lines combine trusted manufacturing standards with innovation.",                   rotate: "rotate-1" },
  { icon: "public",        color: "text-[#ce0301]", title: "Export Ready",      body: "Expanded across local and international markets, giving Coco Cado a strong global platform.",       rotate: "-rotate-1" },
  { icon: "groups",        color: "text-[#f2cdff]", title: "200+ Team",         body: "A dedicated workforce drives the quality and operational strength behind every product.",            rotate: "rotate-1" },
];
---

<BaseLayout
  title="About Coco Cado — Our Story & Brand"
  description="Learn about Coco Cado — a bold Malaysian snack brand backed by Happy Alliance, a trusted food manufacturer since 1996."
>
  <Navbar />

  <main id="main-content">

    <!-- ══════════════ 1. BANNER ══════════════ -->
    <header class="relative pt-32 pb-24 md:pt-48 md:pb-36 bg-[#ffd700] overflow-hidden" aria-labelledby="about-heading">
      <div class="absolute top-10 right-[-5%] w-64 h-64 bg-[#ce0301] rounded-full opacity-20 blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="absolute bottom-[-10%] left-[-5%] w-96 h-96 bg-[#f2cdff] rounded-full opacity-30 blur-3xl pointer-events-none" aria-hidden="true"></div>
      
      <!-- Exploding Pearls Background -->
      <div class="absolute inset-0 z-0 pointer-events-none flex items-center justify-center overflow-hidden" aria-hidden="true">
        <div class="relative w-full h-full max-w-4xl mx-auto">
          <!-- Center group -->
          <Image src={redBeanPearl} alt="" class="pearl-burst absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-20 md:w-32 opacity-0" />
          <Image src={barleyPearl} alt="" class="pearl-burst absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-24 md:w-36 opacity-0" />
          <Image src={waterChesnutPearl} alt="" class="pearl-burst absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-22 md:w-34 opacity-0" />
          
          <!-- Outer scatter -->
          <Image src={redBeanPearl} alt="" class="pearl-burst absolute top-1/3 left-1/4 w-16 md:w-24 opacity-0" />
          <Image src={barleyPearl} alt="" class="pearl-burst absolute top-2/3 right-1/4 w-14 md:w-20 opacity-0" />
          <Image src={waterChesnutPearl} alt="" class="pearl-burst absolute top-1/4 right-1/3 w-18 md:w-26 opacity-0" />
        </div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
        <div class="inline-block bg-[#ce0301] text-white px-4 py-1 rounded-full font-black font-headline tracking-widest uppercase text-sm mb-6 -rotate-2">
          Since 1996
        </div>
        <h1 id="about-heading" class="text-5xl md:text-8xl font-black font-headline text-[#1a0a00] leading-[0.9] tracking-tighter mb-8 uppercase italic">
          About <br /><span class="text-[#ce0301]">Coco Cado</span>
        </h1>
        <p class="max-w-2xl mx-auto text-xl md:text-2xl font-medium text-[#3d1f00] leading-tight">
          A snack brand built on flavour, quality, and the joy of sharing.
        </p>
      </div>

      <div class="absolute top-[25%] hidden lg:block z-20 pointer-events-none animate-float" aria-hidden="true">
        <Image 
          src={redBeanSpoonImg} 
          alt="Juicy Popping Pearl on a spoon" 
          width={400} 
          class="w-64 md:w-[450px] h-auto drop-shadow-2xl"
        />
      </div>
      <div class="absolute bottom-[-15%] -right-24 hidden lg:block z-20 pointer-events-none animate-float [animation-delay:1s]" aria-hidden="true">
        <Image 
          src={barleyBowlImg} 
          alt="Freshly prepared Barley Popping Pearls in a bowl" 
          width={600} 
          class="w-72 md:w-[600px] h-auto drop-shadow-2xl"
        />
      </div>
    </header>

    <!-- ══════════════ 2. OUR STORY ══════════════ -->
    <section class="bg-[#200f01] py-24" aria-labelledby="story-heading">
      <div class="max-w-7xl mx-auto px-6 flex flex-col lg:flex-row gap-16 items-center">
        <!-- Image side (60% width) -->
        <div class="relative w-full lg:w-3/5">
          <figure class="rounded-xl overflow-hidden border-4 border-[#999077] rotate-2 hover:rotate-0 transition-transform duration-500 m-0">
            <Image
              src={building}
              alt="Coco Cado snack brand story — bold flavours crafted with care"
              width={900} height={600}
              loading="lazy" decoding="async"
              class="w-full h-auto bg-[#2c1810]"
            />
          </figure>
          <div class="absolute -bottom-30 -right-8 bg-[#ce0301] text-white p-8 rounded-xl font-black font-headline text-4xl -rotate-3 shadow-2xl z-20" aria-hidden="true">
            BORN<br />BOLD
          </div>
        </div>

        <!-- Text side (40% width) -->
        <div class="w-full lg:w-2/5 space-y-8">
          <h2 id="story-heading" class="text-4xl md:text-6xl font-black font-headline text-[#ffd700] leading-none uppercase italic">
            Our Story
          </h2>
          <div class="h-2 w-32 bg-[#f2cdff]" aria-hidden="true"></div>
          <p class="text-lg md:text-xl text-[#d0c6ab] font-medium leading-relaxed">
            Coco Cado was created to bring a fresh and exciting energy to the snack category.
            Built for a new generation of consumers, the brand combines playful appeal with
            dependable product quality — celebrating fun, flavour, and everyday happiness.
          </p>
          <blockquote class="border-l-8 border-[#ce0301] pl-6 py-4">
            <p class="text-2xl md:text-3xl font-black font-headline italic text-[#ffdcc0] leading-tight">
              "We build snacks for the bold, the curious, and the flavour-seekers who refuse to settle for bland."
            </p>
          </blockquote>
          <p class="text-lg text-[#d0c6ab]">
            From our first product launch to expanding across retail and export channels,
            Coco Cado continues to push the boundaries of what a snack brand can be.
          </p>
        </div>
      </div>
    </section>

    <!-- ══════════════ 3. BRAND CONCEPT ══════════════ -->
    <section class="py-20 px-6 bg-[#200f01]" aria-labelledby="concept-heading">
      <div class="max-w-7xl mx-auto">
        <div class="bg-[#ce0301] rounded-xl p-12 md:p-24 relative overflow-hidden flex flex-col md:flex-row items-center gap-12 -rotate-1">
          <div class="absolute top-0 right-0 p-8 opacity-10 pointer-events-none" aria-hidden="true">
            <span class="material-symbols-outlined text-[200px]">celebration</span>
          </div>
          <div class="flex-1 z-10 space-y-6">
            <h2 id="concept-heading" class="text-4xl md:text-7xl font-black font-headline text-white leading-none uppercase">
              Our Brand<br />Concept
            </h2>
            <p class="text-2xl md:text-4xl font-extrabold font-headline text-[#ffd700] italic uppercase tracking-tight">
              Enjoyable, expressive, easy to love.
            </p>
            <p class="text-white/80 text-lg leading-relaxed max-w-lg">
              At Coco Cado, we believe snacking should feel enjoyable, expressive, and easy to love.
              Our products deliver satisfying crunch, attractive packaging, and flavours that appeal across different ages and occasions.
            </p>
          </div>
          <div class="flex-1 z-10 grid grid-cols-1 gap-6">
            {concepts.map(({ num, title, body }, i) => (
              <div class:list={["bg-[#200f01]/30 backdrop-blur-md p-6 rounded-lg border-4 border-[#999077]", i % 2 === 0 ? "rotate-1" : "-rotate-2"]}>
                <h3 class="text-xl font-black font-headline text-white mb-2">{num}. {title}</h3>
                <p class="text-white/80">{body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════ 4. HAPPY ALLIANCE ══════════════ -->
    <section class="bg-[#2a1705] py-24 relative overflow-hidden" aria-labelledby="alliance-heading">
      <div class="absolute inset-0 opacity-5 pointer-events-none" style="background-image: radial-gradient(#ffd700 1px, transparent 1px); background-size: 30px 30px;" aria-hidden="true"></div>
      <div class="max-w-7xl mx-auto px-6 relative z-10 flex flex-col md:flex-row gap-16 items-center">
        <div class="md:w-1/3 text-center md:text-left space-y-6">
          <div class="inline-flex items-center justify-center w-32 h-32 rounded-full bg-[#ffd700] shadow-2xl rotate-12" aria-hidden="true">
            <span class="text-[#221b00] font-black font-headline text-3xl">1996</span>
          </div>
          <h2 id="alliance-heading" class="text-4xl font-black font-headline text-white">
            Backed by<br />Happy Alliance
          </h2>
          <p class="text-[#d0c6ab] font-medium leading-relaxed">
            Coco Cado is proudly backed by Happy Alliance (M) Sdn. Bhd., a Malaysian food
            manufacturer founded in 1996 with a workforce of more than 200 staff.
          </p>
        </div>
        <ul class="md:w-2/3 grid grid-cols-1 md:grid-cols-2 gap-8 list-none m-0 p-0" role="list" aria-label="Happy Alliance strengths">
          {alliancePoints.map(({ icon, color, title, body, rotate }) => (
            <li class:list={["bg-[#3a2512] p-8 rounded-xl border-4 border-[#999077] hover:-translate-y-2 transition-transform", rotate]}>
              <div class="flex items-center gap-4 mb-4">
                <span class:list={["material-symbols-outlined text-4xl", color]} aria-hidden="true">{icon}</span>
                <h3 class="text-xl font-bold font-headline text-white">{title}</h3>
              </div>
              <p class="text-[#d0c6ab]">{body}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ══════════════ 5. CERTIFICATIONS ══════════════ -->
    <section class="py-24 bg-[#200f01]" aria-labelledby="quality-heading">
      <div class="max-w-7xl mx-auto px-6 text-center">
        <h2 id="quality-heading" class="text-4xl md:text-5xl font-black font-headline text-[#ffd700] mb-6 uppercase italic">
          Manufacturing Strength<br />&amp; Quality Commitment
        </h2>
        <p class="max-w-2xl mx-auto text-[#d0c6ab] text-lg mb-16 leading-relaxed">
          Happy Alliance operates with stringent quality control and holds the following certifications:
        </p>
      </div>

      <!-- Full-Width Marquee -->
      <div class="relative py-20 overflow-hidden w-full my-12">
        <!-- Background Banner Ribbon -->
        <div class="absolute inset-0 bg-[#ffd700] -rotate-1 scale-105 shadow-2xl" aria-hidden="true">
          <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#200f01 1px, transparent 1px); background-size: 20px 20px;"></div>
        </div>

        <div class="relative overflow-hidden py-10 z-10">
          <div class="flex whitespace-nowrap gap-8 md:gap-16 w-max animate-marquee" id="cert-marquee">
            {/* Double the list for seamless looping */}
            {[...certifications, ...certifications].map(({ img, label }) => (
              <div class="inline-flex bg-white p-4 md:p-6 rounded-2xl shadow-xl border-2 border-[#200f01] w-32 md:w-48 aspect-square items-center justify-center shrink-0">
                <Image 
                  src={img} 
                  alt={label} 
                  width={200}
                  class="w-full h-auto object-contain"
                />
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="max-w-7xl mx-auto px-6 text-center">
        <p class="mt-4 max-w-3xl mx-auto text-[#d0c6ab] text-lg leading-relaxed">
          This gives Coco Cado a strong platform for retail confidence, business partnerships,
          and future market expansion both locally and internationally.
        </p>
      </div>
    </section>

    <!-- ══════════════ 6. TIMELINE ══════════════ -->
    <section class="py-24 bg-[#2a1705] relative overflow-hidden" aria-labelledby="timeline-heading">
      <div class="max-w-7xl mx-auto px-6">
        <h2 id="timeline-heading" class="text-4xl font-black font-headline text-white text-center mb-16 uppercase">
          From Manufacturing Experience<br />to New Brand Growth
        </h2>
        <div class="relative">
          <div class="absolute top-8 left-0 w-full h-1 bg-[#4d4732]/30 hidden md:block" aria-hidden="true"></div>
          <ol class="grid md:grid-cols-4 gap-8 list-none m-0 p-0" role="list" aria-label="Brand timeline">
            {milestones.map(({ year, title, body, bg, text, rotate, offset }) => (
              <li class:list={["relative z-10 flex flex-col items-center", offset]}>
                <div class:list={["w-16 h-16 rounded-full flex items-center justify-center font-black font-headline text-lg mb-6 shadow-lg border-4 border-[#200f01]", bg, text]}>
                  {year}
                </div>
                <div class:list={["bg-[#200f01] p-6 rounded-xl border-4 border-[#999077] text-center w-full", rotate]}>
                  <h3 class="font-black font-headline text-[#ffd700] mb-2 uppercase">{title}</h3>
                  <p class="text-sm text-[#d0c6ab]">{body}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray<HTMLElement>("section, header").forEach((el) => {
    const children = el.querySelectorAll<HTMLElement>("h1, h2, h3, p, li, blockquote, figure");
    if (!children.length) return;
    gsap.fromTo(children,
      { opacity: 0, y: 30 },
      { opacity: 1, y: 0, duration: 0.7, stagger: 0.08, ease: "power2.out",
        scrollTrigger: { trigger: el, start: "top 80%", once: true } }
    );
  });

  // Pearl Explosion Animation
  gsap.set(".pearl-burst", { scale: 0, opacity: 0 });
  gsap.to(".pearl-burst", {
    scale: 1,
    opacity: 0.8,
    duration: 1.5,
    stagger: 0.1,
    ease: "elastic.out(1, 0.5)",
    x: () => (Math.random() - 0.5) * 800,
    y: () => (Math.random() - 0.5) * 400,
    rotate: () => Math.random() * 360,
    delay: 0.5
  });

  // Infinite floating for pearls
  gsap.to(".pearl-burst", {
    y: "+=20",
    x: "+=15",
    rotate: "+=10",
    duration: "random(2, 4)",
    repeat: -1,
    yoyo: true,
    ease: "sine.inOut",
    delay: 2
  });

  gsap.to("#cert-marquee", {
    xPercent: -50,
    ease: "none",
    duration: 30,
    repeat: -1
  });

  gsap.fromTo(
    "#cert-marquee",
    { opacity: 0 },
    { opacity: 1, duration: 1, delay: 0.5, scrollTrigger: { trigger: "#cert-marquee", start: "top 90%", once: true } }
  );

  gsap.fromTo(
    "ol[aria-label='Brand timeline'] li",
    { opacity: 0, y: 40 },
    { opacity: 1, y: 0, duration: 0.6, stagger: 0.15, ease: "power2.out",
      scrollTrigger: { trigger: "ol[aria-label='Brand timeline']", start: "top 80%", once: true } }
  );
</script>

<style is:global>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }
  .animate-float {
    animation: float 5s ease-in-out infinite;
  }
</style>