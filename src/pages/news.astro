---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import NewsHeroStitch from "../components/news/NewsHeroStitch.astro";
import NewsTickerStitch from "../components/news/NewsTickerStitch.astro";
import NewsCardStitch from "../components/news/NewsCardStitch.astro";
import NewsPaginationStitch from "../components/news/NewsPaginationStitch.astro";
import NewsCTAStitch from "../components/news/NewsCTAStitch.astro";

// Import Real Images
import news1 from "../assets/news/news1.jpg";

const tickerItems = [
  "Product Launches",
  "Campaign Announcements",
  "Trade Shows",
  "Community Events",
  "Ambassador Activities",
  "Retail Promotions"
];

const newsItems = [
  {
    title: "Star singer Khai Bahar is on a starry high his new single hitting the charts and now also official brand ambassador for top food brand",
    excerpt: "The popular singer-actor has officially joined the Coco Cado family as our brand ambassador, marking a significant milestone in our journey to bring bold flavours to more fans.",
    category: "News",
    date: "Wednesday, 19 Nov 2025",
    image: news1,
    href: "https://www.thestar.com.my/aseanplus/aseanplus-news/2025/11/19/star-singer-khai-bahar-is-on-a-starry-high-his-new-single-hitting-the-charts-and-now-also-official-brand-ambassador-for-top-food-brand",
    tagColor: "#ce0301",
    borderColor: "border-[#200f01]",
    shadowColor: "#200f01",
    isFeatured: true
  },
  // {
  //   title: "SUMMER OF SNACKS 2024",
  //   excerpt: "Our nationwide tour kicking off in Miami this June with 10,000 samples.",
  //   category: "Campaigns",
  //   date: "Monday, 10 Jun 2024",
  //   tagColor: "#8243a2",
  //   borderColor: "border-[#8243a2]",
  //   shadowColor: "#8243a2"
  // },
  // {
  //   title: "GLOBAL SNACK EXPO RECAP",
  //   excerpt: "How Coco Cado took home the 'Innovative Snack of the Year' award in Chicago.",
  //   category: "Trade Shows",
  //   date: "Friday, 15 Mar 2024",
  //   tagColor: "#008080",
  //   borderColor: "border-[#008080]",
  //   shadowColor: "#008080"
  // },
  // {
  //   title: "NOW AT SELECT WHOLE FOODS",
  //   excerpt: "Find our signature crunchy sticks in the organic snacks aisle nationwide.",
  //   category: "Retail Promotions",
  //   date: "Tuesday, 20 Feb 2024",
  //   tagColor: "#ce0301",
  //   borderColor: "border-[#ce0301]",
  //   shadowColor: "#ce0301"
  // },
  // {
  //   title: "CRUNCH FOR A CAUSE",
  //   excerpt: "Supporting local urban gardens one snack bag at a time. Join the initiative.",
  //   category: "Community",
  //   date: "Sunday, 05 Jan 2024",
  //   tagColor: "#2e7d32",
  //   borderColor: "border-[#2e7d32]",
  //   shadowColor: "#2e7d32"
  // }
];

// Pagination Logic
const itemsPerPage = 5;
const totalPages = Math.ceil(newsItems.length / itemsPerPage);
const currentPage = parseInt(Astro.url.searchParams.get('page') || '1');
const startIndex = (currentPage - 1) * itemsPerPage;
const endIndex = startIndex + itemsPerPage;
const currentItems = newsItems.slice(startIndex, endIndex);
---

<BaseLayout 
  title="News & Media — Coco Cado" 
  description="Stay updated with our latest campaigns, launches, events, and brand milestones."
>
  <Navbar />

  <main id="main-content" class="bg-[#ffd700] pt-24">
    <NewsHeroStitch 
      title="Campaign & Moment"
      subtitle="Stay updated with our latest campaigns, launches, events, and brand milestones."
    />

    <NewsTickerStitch items={tickerItems} />

    <section class="py-24 px-6 max-w-4xl mx-auto text-center border-t border-[#200f01]/10">
      <p class="font-body text-xl md:text-2xl text-[#200f01] leading-relaxed font-medium opacity-80">
        Follow Coco Cado's latest updates as we grow the brand through product launches, roadshows, collaborations, exhibitions, and retail campaigns.
      </p>
    </section>

    <section class="px-6 pb-24">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-6 gap-x-12 gap-y-20 news-grid-force">
        {currentItems.map((item) => (
          <NewsCardStitch 
            title={item.title}
            excerpt={item.excerpt}
            category={item.category}
            date={item.date}
            image={item.image}
            href={item.href}
            tagColor={item.tagColor}
            borderColor={item.borderColor}
            shadowColor={item.shadowColor}
            isFeatured={item.isFeatured}
          />
        ))}
      </div>
    </section>

    <NewsPaginationStitch totalPages={totalPages} currentPage={currentPage} />

    <NewsCTAStitch 
      title="WANT TO STAY IN THE LOOP?"
      subtitle="Get the latest news and drops delivered straight to your social feed."
      buttonText="FOLLOW US"
    />
  </main>

  <Footer />
</BaseLayout>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import Lenis from "lenis";

  gsap.registerPlugin(ScrollTrigger);

  function initNews() {
    const lenis = new Lenis();
    gsap.ticker.add((time) => {
      lenis.raf(time * 1000);
    });
    lenis.on('scroll', ScrollTrigger.update);

    const heroTl = gsap.timeline({ defaults: { ease: "power3.out", duration: 1 } });
    heroTl
      .fromTo(".hero-animate-reveal", 
        { y: 30, opacity: 0 },
        { y: 0, opacity: 1, stagger: 0.1, delay: 0.2 }
      );

    const cards = document.querySelectorAll(".news-card-reveal");
    
    if (cards.length > 0) {
      gsap.set(".news-card-reveal", { y: 60, opacity: 0, visibility: "visible" });

      ScrollTrigger.batch(".news-card-reveal", {
        start: "top 95%", 
        onEnter: batch => gsap.to(batch, { opacity: 1, y: 0, stagger: 0.15, duration: 1, ease: "power3.out" }),
        once: true
      });
    }

    ScrollTrigger.refresh();
  }

  document.addEventListener('astro:page-load', initNews);
  
  if (document.readyState === 'complete') {
    initNews();
  } else {
    window.addEventListener('load', initNews);
  }
</script>

<style is:global>
  .news-card-reveal {
    opacity: 0;
    visibility: hidden;
  }
  
  @media (min-width: 1024px) {
    .news-grid-force {
      display: grid !important;
      grid-template-columns: repeat(6, 1fr) !important;
      gap: 3rem !important;
    }
    
    .news-grid-force > *:nth-child(1) {
      grid-column: span 4 !important;
    }
    .news-grid-force > *:nth-child(2) {
      grid-column: span 2 !important;
    }
    
    .news-grid-force > *:nth-child(n+3) {
      grid-column: span 2 !important;
    }
  }
</style>
