---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import AmbassadorHeroStitch from "../components/ambassadors/AmbassadorHeroStitch.astro";
import AmbassadorIntroStitch from "../components/ambassadors/AmbassadorIntroStitch.astro";
import AmbassadorProfileStitch from "../components/ambassadors/AmbassadorProfileStitch.astro";
import CampaignMomentsStitch from "../components/ambassadors/CampaignMomentsStitch.astro";
import BrandCollabCTAStitch from "../components/ambassadors/BrandCollabCTAStitch.astro";
import MarqueeStripStitch from "../components/ambassadors/MarqueeStripStitch.astro";
import KhaiImage from "../assets/KhaiAmbassador.png";
---

<BaseLayout 
  title="Ambassadors — Coco Cado" 
  description="Meet the crew that brings the crunch. Our ambassadors are the heartbeat of the Coco Cado carnival."
>
  <Navbar />

  <main id="main-content">
    <AmbassadorHeroStitch 
      tag="Family & Friends"
      titleLine1="Ambassadors"
      titleLine2="& Brand"
      titleLine3="Partners"
      subtitle="Bringing the Coco Cado brand to life through engaging personalities and collaborations."
      badge="Join the<br/>Squad"
      image="https://lh3.googleusercontent.com/aida-public/AB6AXuDNhzgkheWo2kvjlR_ymA3EhHQpr6tpiDiMkhvizRdV2WuAGBf3-FpzOlsVAFMh7-pH390v4y4fpW16EoiuBR-ile1jhFao_5dlsiMVXn_dELur8KHfe1mn9nWz9KqVbjIN4QnlILg55nkU9BYzZ3XBtcwK6kSZn2mp0R-gFxhGBcWL3Cq0JySTHAhQnBuZvCFAGKrdtLA6Yqm5KkwsDY5sj6aOEEryfmO6IiyNJ4UrlRNH5-8anPDuu0jD-iToT0wS2FMrlu8M2yQ"
      imageAlt="Group of diverse gen-z friends laughing and eating snacks"
    />

    <AmbassadorIntroStitch>
      Coco Cado works with ambassadors, <span class="text-[#ffd700]">creators</span>, 
      and <span class="text-[#f2cdff]">brand partners</span> who match the spirit 
      of the brand <span class="text-primary-container">fun</span>, 
      <span class="text-secondary-container underline-wavy">energetic</span>, 
      <span class="text-[#f2cdff] italic">relatable</span>, and 
      <span class="text-[#ffd700]">full of life</span>. Through launches, 
      <span class="text-secondary-container">digital campaigns</span>, 
      event appearances, and <span class="text-[#f2cdff]">branded storytelling</span>, 
      these collaborations help Coco Cado connect with wider audiences in a 
      fresh and <span class="text-primary-container italic">memorable way</span>.
    </AmbassadorIntroStitch>

    <section class="py-12 space-y-32 mb-32">
      <div class="max-w-7xl mx-auto px-6">
        <h3 class="font-headline font-black text-4xl md:text-5xl uppercase tracking-tighter mb-20 text-white">
          Meet Our Ambassadors
        </h3>
        
        <AmbassadorProfileStitch 
          name="Khai"
          lastName="Bahar"
          role="Brand Ambassador"
          description="As one of the faces of Coco Cado, Khai Bahar brings charm, visibility, and authentic connection to the brand. Through content, appearances, and campaigns, they help share the fun and flavour of Coco Cado with consumers nationwide."
          image={KhaiImage.src}
          imageAlt="Khai Bahar posing with a snack bag"
          badgeColor="bg-[#f2cdff] text-[#310049]"
          accentBg="bg-[#ce0301]"
          socialLinks={[
            { 
              label: "Instagram", 
              link: "https://www.instagram.com/khaibahar94/", 
              isSvg: true, 
              svgPath: "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" 
            },
            { 
              label: "TikTok", 
              link: "https://www.tiktok.com/@cococadomy", 
              isSvg: true, 
              svgPath: "M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.04-.1z" 
            }
          ]}
        />
      </div>
    </section>

    <CampaignMomentsStitch />

    <BrandCollabCTAStitch 
      titleLine1="Brand"
      titleLine2="Collaborations"
      description="We partner with brands that share our vision for chaotic joy and premium flavor. Ready to create something iconic?"
      buttonText="Get In Touch"
      buttonHref="/contact"
    />

    <MarqueeStripStitch 
      text1="Want to collaborate with Coco Cado?"
      text2="Join the Carnival"
      text3="Crunch with us"
    />
  </main>

  <Footer />
</BaseLayout>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import Lenis from "lenis";

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('load', () => {
    // 1. Smooth Scroll
    const lenis = new Lenis();
    gsap.ticker.add((time) => {
      lenis.raf(time * 1000);
    });
    lenis.on('scroll', ScrollTrigger.update);

    // 2. Hero Entrance
    const heroTl = gsap.timeline({ defaults: { ease: "power4.out", duration: 1.2 } });
    heroTl
      .fromTo(".hero-animate-reveal", 
        { y: 60, opacity: 0 },
        { y: 0, opacity: 1, stagger: 0.15, delay: 0.2 }
      )
      .fromTo(".hero-animate-badge", 
        { scale: 0, rotation: -20 },
        { scale: 1, rotation: 12, duration: 1, ease: "back.out(2)" },
        "-=0.8"
      )
      .fromTo(".hero-animate-image", 
        { x: 100, opacity: 0, rotation: 10 },
        { x: 0, opacity: 1, rotation: 2, duration: 1.5 },
        "-=1.2"
      );

    // 3. Intro Reveal - Handled by component internal script for word-by-word reveal

    // 4. Profiles Reveal
    const profiles = document.querySelectorAll('.grid');
    profiles.forEach((profile) => {
      const content = profile.querySelector('.profile-animate-content');
      const image = profile.querySelector('.profile-animate-image');
      
      if (content && image) {
        gsap.fromTo(image, 
          { x: profile.classList.contains('md:order-2') ? 100 : -100, opacity: 0 },
          { 
            x: 0, opacity: 1, 
            duration: 1.2,
            scrollTrigger: {
              trigger: profile,
              start: "top 75%",
              once: true
            }
          }
        );
        gsap.fromTo(content, 
          { y: 60, opacity: 0 },
          { 
            y: 0, opacity: 1, 
            duration: 1, 
            delay: 0.2,
            scrollTrigger: {
              trigger: profile,
              start: "top 75%",
              once: true
            }
          }
        );
      }
    });

    // 5. Gallery Reveal
    gsap.fromTo(".gsap-reveal-moment", 
      { scale: 0.8, opacity: 0, y: 40 },
      { 
        scale: 1, opacity: 1, y: 0,
        stagger: 0.1,
        duration: 0.8,
        ease: "power2.out",
        scrollTrigger: {
          trigger: ".gsap-reveal-moment",
          start: "top 85%",
          once: true
        }
      }
    );

    ScrollTrigger.refresh();
  });
</script>
