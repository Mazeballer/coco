---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ProductHeroStitch from "../components/products/ProductHeroStitch.astro";
import ProductCategoryStitch from "../components/products/ProductCategoryStitch.astro";
import ProductCardStitch from "../components/products/ProductCardStitch.astro";
import { products } from "../data/productData";
import productPageImg from "../assets/productpage.svg";

const potatoSticks = products.filter(p => p.category === "Potato Sticks");
const poppingPearls = products.filter(p => p.category === "Popping Pearl");
---

<BaseLayout 
  title="Our Snacks — Coco Cado" 
  description="Explore the full range of Coco Cado snacks, from our famous crispy Potato Sticks to our fun Popping Pearls."
>
  <Navbar />

  <main id="main-content">
    <!-- Hero Section -->
    <ProductHeroStitch 
      title="Our Snacks"
      subtitle="Big flavour. Real crunch. Every pack, every moment."
      image={productPageImg}
      imageAlt="A variety of Coco Cado snacks showcased in a premium, artistic bowl"
    />

    <!-- Potato Sticks Category -->
    <ProductCategoryStitch
      title="Potato Sticks"
      subtitle="Light, crispy, and seriously addictive."
      badge="STARCH-POWERED FUN"
      colors={{
        bg: "bg-primary-container",
        text: "text-on-primary-fixed",
        badgeBg: "bg-on-primary-fixed",
        badgeText: "text-primary-container"
      }}
    >
      {potatoSticks.map((p, i) => (
        <ProductCardStitch 
          slug={p.slug}
          title={p.name}
          description={p.description}
          image={p.mainImage}
          imageAlt={p.mainImageAlt}
          badge={p.badge}
          badgeColor={p.badgeColor}
          badgeTextColor={p.badgeTextColor}
          tags={p.tags}
          rotate={i % 2 === 0 ? "-rotate-1" : "rotate-1"}
          mt={i === 1 ? "md:mt-12" : ""}
        />
      ))}
    </ProductCategoryStitch>

    <!-- Wavy Divider -->
    <div class="h-24 bg-primary-container relative z-10">
      <div class="absolute bottom-0 left-0 w-full h-full bg-[#CC0000] wavy-divider-stitch"></div>
    </div>

    <!-- Popping Pearl Category -->
    <ProductCategoryStitch
      title="Popping Pearl"
      subtitle="Soft, flavourful, and fun to eat."
      badge="POP TILL YOU DROP"
      reverse={true}
      colors={{
        bg: "bg-[#CC0000]",
        text: "text-white",
        badgeBg: "bg-white",
        badgeText: "text-[#CC0000]"
      }}
    >
      {poppingPearls.map((p, i) => (
        <ProductCardStitch 
          slug={p.slug}
          title={p.name}
          description={p.description}
          image={p.mainImage}
          imageAlt={p.mainImageAlt}
          badge={p.badge}
          badgeColor={p.badgeColor}
          badgeTextColor={p.badgeTextColor}
          tags={p.tags}
          rotate={i % 2 === 0 ? "rotate-2" : "-rotate-1"}
          mt={i === 1 ? "mt-8" : ""}
        />
      ))}
    </ProductCategoryStitch>
  </main>

  <Footer />
</BaseLayout>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import Lenis from "lenis";

  // Register GSAP plugins
  gsap.registerPlugin(ScrollTrigger);

  // Initialize animations once the page is fully loaded
  window.addEventListener('load', () => {
    // 1. Initialize Lenis Smooth Scroll
    const lenis = new Lenis({
      duration: 1.2,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: true,
    });

    // Synchronize ScrollTrigger with Lenis
    lenis.on('scroll', ScrollTrigger.update);
    
    gsap.ticker.add((time) => {
      lenis.raf(time * 1000);
    });

    // 2. Hero Entrance Animation
    const heroTl = gsap.timeline({ defaults: { ease: "power4.out", duration: 1.2 } });

    heroTl
      .fromTo(".hero-animate-reveal", 
        { y: 60, opacity: 0 },
        { y: 0, opacity: 1, stagger: 0.15, delay: 0.2 }
      )
      .fromTo(".hero-animate-image", 
        { scale: 0.8, rotation: 10, opacity: 0 },
        { scale: 1, rotation: 3, opacity: 1, duration: 1.5, ease: "back.out(1.7)" },
        "-=1"
      );

    // 3. Product Cards Stagger Reveal
    const categories = document.querySelectorAll('section');
    
    categories.forEach((category) => {
      const grid = category.querySelector('.product-grid');
      const cards = category.querySelectorAll('.product-card-reveal');
      
      if (grid && cards.length > 0) {
        gsap.fromTo(cards, 
          { y: 50, opacity: 0, rotation: 2 },
          {
            y: 0,
            opacity: 1,
            rotation: 0,
            stagger: 0.1,
            duration: 0.8,
            ease: "power2.out",
            scrollTrigger: {
              trigger: grid,
              start: "top 70%",
              once: true,
            }
          }
        );
      }

      // Also reveal category titles
      const titles = category.querySelectorAll('h2, .rounded-full');
      if (titles.length > 0) {
        gsap.fromTo(titles, 
          { y: 30, opacity: 0 },
          {
            y: 0,
            opacity: 1,
            stagger: 0.08,
            duration: 0.8,
            ease: "power3.out",
            scrollTrigger: {
              trigger: category,
              start: "top 80%",
              once: true,
            }
          }
        );
      }
    });

    // Final refresh to lock in positions
    ScrollTrigger.refresh();
  });
</script>
